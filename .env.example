# =============================================================
# NUEVO SISTEMA DE ASISTENCIA — Variables de Entorno
# Copia este archivo como .env y completa los valores
# =============================================================

# ─── Base de Datos NUEVA (MySQL propio del nuevo sistema) ─────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=asistencia
DB_USER=asistencia_user
DB_PASSWORD=password_seguro_aqui
DB_ROOT_PASSWORD=rootpass_cambia_esto

# ─── Base de Datos ORIGEN: att2000 (SQL Server del ZK) ───────
# SOLO LECTURA — El nuevo sistema NUNCA escribe aquí por defecto
ATT_HOST=<hostname_o_ip_servidor_sqlserver>
ATT_PORT=1433                # Puerto SQL Server (default: 1433)
ATT_USER=sa                  # Usuario SQL Server
ATT_PASSWORD=                # Contraseña del sa
ATT_DATABASE=att2000         # Base de datos del ZK Attendance

# ─── Control att2000 ─────────────────────────────────────────
ATT2000_ALLOW_WRITE=false              # NUNCA cambiar a true salvo caso muy excepcional
ATT2000_INCREMENTAL_ENABLED=false      # Activar sync incremental automático
ATT2000_INCREMENTAL_CRON=*/5 * * * *  # Frecuencia de sync incremental
ATT2000_SAFETY_WINDOW_HOURS=24        # Horas de re-importación por seguridad

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=genera_un_string_aleatorio_largo_aqui
JWT_REFRESH_SECRET=otro_string_aleatorio_diferente

# ─── URLs ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000
ANALYTICS_URL=http://localhost:5000
SOCKET_URL=http://localhost:4000

# ─── Claves internas entre servicios ─────────────────────────
BRIDGE_API_KEY=<genera_clave_aleatoria>
ANALYTICS_API_KEY=<genera_clave_aleatoria>
# Para el frontend (prefijo NEXT_PUBLIC_ = visible en browser, NO poner secretos reales)
NEXT_PUBLIC_ANALYTICS_API_KEY=<clave_publica_analytics>

# ─── Bridge ZKTeco ────────────────────────────────────────────
BRIDGE_URL=http://localhost:8081      # URL interna del bridge (API)
BRIDGE_API_PORT=8081                  # Puerto API bridge
BRIDGE_PUSH_PORT=8080                 # Puerto PUSH de relojes ZKTeco

# ─── Relojes ZKTeco ───────────────────────────────────────────
# Formato: IP:PUERTO separados por comas (no hardcodear IPs de red interna)
ZKTECO_DEVICES=<ip_reloj1>:4370,<ip_reloj2>:4370
ZKTECO_PORT=4370
ZKTECO_POLL_INTERVAL=30000

# ─── Notification Channels ───────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@empresa.com
SMTP_TLS=true

# WhatsApp (WAHA or Meta Cloud API)
WHATSAPP_PROVIDER=WAHA
WAHA_API_URL=http://localhost:3001
WAHA_SESSION=default
META_WHATSAPP_TOKEN=
META_WHATSAPP_PHONE_ID=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# SMS Gateway
SMS_PROVIDER=HTTP
SMS_API_URL=
SMS_API_KEY=

# Web Push (VAPID keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@empresa.com

# ─── Document Storage ─────────────────────────────────────────
DOCUMENT_STORAGE_PATH=./uploads/documents
MAX_FILE_SIZE_MB=50

# ─── Staging ─────────────────────────────────────────────────
STAGING_EXPOSE_API=false    # Exponer puerto API 4000 directamente (staging solo)
NODE_ENV=production

# ─── Oracle Legacy (read-only reference, optional) ────────────
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SID=ANAM
ORACLE_USER=
ORACLE_PASSWORD=
